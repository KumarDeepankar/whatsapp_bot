# AWS S3 Configuration (Optional - for S3 file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name
S3_FOLDER_PREFIX=uploads/

# OpenAI Configuration (Optional - for text extraction from images)
OPENAI_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4o-mini

# File Processing
MAX_FILE_SIZE_MB=50

# OpenSearch Configuration (for WhatsApp Bot Knowledge Base)
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX_NAME=whatsapp_knowledge_base

# ===========================================
# Embedding Provider Configuration
# ===========================================
# Options: "gemini" or "ollama"
EMBEDDING_PROVIDER=gemini

# --- Google Gemini Configuration ---
# Required if EMBEDDING_PROVIDER=gemini
# Also required for image OCR regardless of embedding provider
GOOGLE_API_KEY=your_google_api_key
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# --- Ollama Configuration (Local) ---
# Required if EMBEDDING_PROVIDER=ollama
# Make sure Ollama is running: `ollama serve`
# Pull a model first: `ollama pull nomic-embed-text`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=60
